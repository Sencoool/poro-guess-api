// prisma/schema.prisma

generator client {
  provider      = "prisma-client"
  output        = "../src/generated/prisma"
  moduleFormat  = "cjs"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

// ── Enums ────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum Rank {
  IRON
  BRONZE
  SILVER
  GOLD
  PLATINUM
  EMERALD
  DIAMOND
  MASTER
  GRANDMASTER
  CHALLENGER
}

enum ChampionRole {
  TOP
  JUNGLE
  MID
  BOT
  SUPPORT
}

enum DamageType {
  PHYSICAL
  MAGIC
}

enum Resource {
  MANA
  MANALESS
  ENERGY
  RAGE
  NONE
}

enum RangeType {
  MELEE
  RANGE
}

enum Gender {
  MALE
  FEMALE
}

enum Mode {
  CLASSIC
  JIGSAW
  TRAITS
  MATCHER
}

// ── Models ───────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  email     String?  @unique
  username  String   @unique
  password  String?
  role      Role     @default(USER)
  isGuest   Boolean  @default(false)
  isActive  Boolean  @default(true)
  score     Int      @default(0)
  rank      Rank     @default(IRON)
  streak    Int      @default(0)
  lastLogin DateTime @default(now())
  lastPlayedAt DateTime?
  iconPath  String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userDailyProgress UserDailyProgress[]

  @@index([score, rank, streak])
  @@map("users")
}

model Champion {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  gender          Gender
  role            ChampionRole
  damageType      DamageType
  resource        Resource
  rangeType       RangeType
  yearRelease     Int
  traits          String[]         @default([])
  iconPath        String
  splashPath      String[]
  hint            String
  dailyChallenges DailyChallenge[]
  dailyGuesses    DailyGuess[]

  @@map("champions")
}

model DailyChallenge {
  id           Int          @id @default(autoincrement())
  mode         Mode
  championsId  Int?
  champion     Champion?    @relation(fields: [championsId], references: [id])
  matcherChampions Int[]    @default([])
  dailyGuesses DailyGuess[]
  userDailyProgress UserDailyProgress[]

  @@unique([championsId, mode])
  @@map("daily_challenges")
}

model DailyGuess {
  id               Int             @id @default(autoincrement())
  guessCount       Int             @default(0)
  championsId      Int
  champion         Champion        @relation(fields: [championsId], references: [id])
  dailyChallengeId Int
  dailyChallenge   DailyChallenge? @relation(fields: [dailyChallengeId], references: [id]) // Count guess for each mode

  @@unique([dailyChallengeId, championsId])
  @@map("daily_guesses")
}

model UserDailyProgress {
  id               Int            @id @default(autoincrement())
  userId           String
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyChallengeId Int
  dailyChallenge   DailyChallenge @relation(fields: [dailyChallengeId], references: [id], onDelete: Cascade)
  guessedChampions Int[]          @default([])
  isWon            Boolean        @default(false)
  moves            Int?
  timeElapsed      Int?

  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@unique([userId, dailyChallengeId])
  @@map("user_daily_progress")
}

